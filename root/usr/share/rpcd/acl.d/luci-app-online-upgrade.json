{
	"luci-app-online-upgrade": {
		"description": "Grant access to LuCI app online-upgrade",
		"read": {
			"cgi-io": [ "exec" ],
			"file": {
				"/tmp/online-upgrade-status": [ "read" ],
				"/etc/openwrt_release": [ "read" ],
				"/etc/config/online-upgrade": [ "read" ],
				"/etc/config/sysupgrade.tgz": [ "read" ],
				"/usr/bin/online-upgrade.sh": [ "exec" ],
				"/bin/cat": [ "exec" ],
				"/bin/sh": [ "exec" ],
				"/bin/date": [ "exec" ]
			},
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "online-upgrade" ]
		},
		"write": {
			"file": {
				"/etc/config/online-upgrade": [ "write" ]
			},
			"uci": [ "online-upgrade" ]
		}
	}
}
